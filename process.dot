digraph G {
    "target_rule" -> "relay_rule==relay_file" [label="has_relay"]
    "target_rule" [shape=diamond]
    "target_rule" -> "run_command" [label="no_relay"]
    "relay_rule==relay_file" [shape=diamond]
    "relay_rule==relay_file" -> "relay_rule/relay_file" [label="N"]
    "relay_rule/relay_file" [shape=diamond]
    "relay_rule/relay_file" -> "run_relay_rule" [label="relay_rule"]
    "relay_rule/relay_file" -> "n1"  [label="relay_file"]
    "n1" -> "pass" [label="target>relay"]
    "n1" -> "run_command" [label="target<relay"]
    "n1" [label="check_modify_time", shape=diamond]
    "relay_rule==relay_file" -> "n2" [label="Y"]
    "n2" -> "pass" [label="target>relay"]
    "n2" -> "run_relay_rule" [label="target<relay"]
    "n2" [label="check_modify_time", shape=diamond]
    "run_relay_rule" -> "run_command"
}
